# ──────────────────────────────────────────────────────────────
# Akali — environment variables
# Copy this file to `.env` and fill in the values.
# ──────────────────────────────────────────────────────────────

# Node
NODE_ENV=development
LOG_LEVEL=info

# ── Database ────────────────────────────────────────────────────
# Local dev (Postgres exposed by docker compose on host port 5433 to avoid
# clashing with a Postgres already running on 5432):
DATABASE_URL=postgresql://akali:akali@localhost:5433/akali?schema=public

# Credentials used by the `postgres` container (docker compose):
POSTGRES_USER=akali
POSTGRES_PASSWORD=akali
POSTGRES_DB=akali
# Host port mapped to the container's 5432 (change if 5433 is also taken):
POSTGRES_PORT=5433

# ── Discord ─────────────────────────────────────────────────────
# https://discord.com/developers/applications
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
# Optional: register slash-commands instantly in a single guild (dev).
# Leave empty to register commands globally (can take up to 1h to appear).
DISCORD_GUILD_ID=

# ── Worker (video polling) ──────────────────────────────────────
# Cron expression for how often sources are polled.
POLL_INTERVAL_CRON=*/5 * * * *
# Max number of videos posted per source on the first poll (avoids floods).
BACKFILL_LIMIT=3
# YouTube: also include the "Shorts" tab (live streams are always excluded).
YOUTUBE_INCLUDE_SHORTS=true
# If true: download the video with yt-dlp and upload the file to Discord
# (only when it fits under MAX_UPLOAD_MB). If false: post a rich embed + link.
DOWNLOAD_VIDEOS=false
MAX_UPLOAD_MB=25
# Path to the yt-dlp binary (the Docker image installs it on the PATH).
YTDLP_PATH=yt-dlp
