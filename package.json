{
  "name": "akali",
  "version": "0.1.0",
  "private": true,
  "description": "Discord bot that fetches videos from YouTube/Instagram/Twitter/TikTok and posts them live into Discord channels.",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:generate": "pnpm --filter @akali/db generate",
    "db:migrate": "pnpm --filter @akali/db migrate",
    "db:deploy": "pnpm --filter @akali/db deploy",
    "db:studio": "pnpm --filter @akali/db studio",
    "bot:dev": "pnpm --filter @akali/bot dev",
    "worker:dev": "pnpm --filter @akali/worker dev"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "rimraf": "^6.0.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "esbuild",
      "prisma"
    ]
  }
}
